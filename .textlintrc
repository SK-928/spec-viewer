{
  // ==========================================================================
  // textlint 設定（基盤）
  // --------------------------------------------------------------------------
  //   - 検査: pnpm check:text
  //   - 修正: pnpm check:text:fix
  //
  // 既存の textlint ルールを追加する:
  //   1. pnpm add -D textlint-rule-<name>
  //   2. 下の "rules" に "<name>": true を追加
  //      例: "sentences-per-line": true
  //
  // prh 辞書（表記揺れ）を追加する:
  //   prh.yml にルールを追記（prh.yml のコメント参照）
  // ==========================================================================
  "plugins": {},
  "filters": {},
  "rules": {
    // prh: 表記揺れ補正（prh.yml で辞書を管理）
    "prh": {
      "rulePaths": ["./prh.yml"]
    }
  }
}
