{
  "name": "spec-viewer",
  "version": "1.0.0",
  "description": "設計書の閲覧ツール",
  "scripts": {
    "specs:dev": "vitepress dev",
    "specs:build": "vitepress build",
    "specs:preview": "vitepress preview",
    "check": "biome check --changed .",
    "check:fix": "biome check --changed --write .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "SK-928",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vitepress": "2.0.0-alpha.17"
  }
}
